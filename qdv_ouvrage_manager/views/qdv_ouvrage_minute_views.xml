<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         VUE RECHERCHE (définie EN PREMIER car référencée par l'action)
    ============================================================ -->
    <record id="qdv_ouvrage_minute_search" model="ir.ui.view">
        <field name="name">qdv.ouvrage.minute.search</field>
        <field name="model">qdv.ouvrage.minute</field>
        <field name="arch" type="xml">
            <search string="Rechercher des articles">
                <field name="description" string="Description"/>
                <field name="reference" string="Référence"/>
                <field name="fabricant"/>
                <field name="ouvrage_id"/>
                <field name="base_id"/>
                <separator/>
                <filter name="filter_modified" string="Modifiés"
                        domain="[('is_modified', '=', True)]"/>
                <filter name="filter_new" string="Nouveaux"
                        domain="[('is_new', '=', True)]"/>
                <separator/>
                <filter name="filter_materiel" string="🔩 Matériel"
                        domain="[('type_ligne', '=', 'materiel')]"/>
                <filter name="filter_main_oeuvre" string="👷 Main d'œuvre"
                        domain="[('type_ligne', '=', 'main_oeuvre')]"/>
                <group expand="0" string="Grouper par">
                    <filter name="group_ouvrage" string="Ouvrage"
                            context="{'group_by': 'ouvrage_id'}"/>
                    <filter name="group_type" string="Type"
                            context="{'group_by': 'type_ligne'}"/>
                    <filter name="group_fabricant" string="Fabricant"
                            context="{'group_by': 'fabricant'}"/>
                    <filter name="group_base_source" string="Base QDV"
                            context="{'group_by': 'base_source'}"/>
                    <filter name="group_base_id" string="Base d'ouvrage"
                            context="{'group_by': 'base_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================
         VUE LISTE STANDALONE (menu direct)
    ============================================================ -->
    <record id="qdv_ouvrage_minute_list" model="ir.ui.view">
        <field name="name">qdv.ouvrage.minute.list</field>
        <field name="model">qdv.ouvrage.minute</field>
        <field name="arch" type="xml">
            <list string="Articles / Minutes"
                  decoration-info="is_new"
                  decoration-warning="is_modified"
                  decoration-muted="type_ligne == 'main_oeuvre'">
                <field name="base_id" string="Base" optional="show"/>
                <field name="ouvrage_id" string="Ouvrage"/>
                <field name="type_ligne" widget="badge"
                       decoration-primary="type_ligne == 'materiel'"
                       decoration-warning="type_ligne == 'main_oeuvre'"
                       decoration-secondary="type_ligne == 'autre'"/>
                <field name="quantite" string="Qté"/>
                <field name="description"/>
                <field name="reference"/>
                <field name="fabricant" optional="show"/>
                <field name="base_source" string="Base QDV" optional="show"/>
                <field name="is_modified" optional="show"/>
                <!-- Champs requis pour decoration-* mais non affichés -->
                <field name="is_new" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- ============================================================
         VUE FORMULAIRE d'une minute
    ============================================================ -->
    <record id="qdv_ouvrage_minute_form" model="ir.ui.view">
        <field name="name">qdv.ouvrage.minute.form</field>
        <field name="model">qdv.ouvrage.minute</field>
        <field name="arch" type="xml">
            <form string="Article / Minute">
                <sheet>
                    <widget name="web_ribbon" title="Modifié" bg_color="bg-warning"
                            invisible="not is_modified"/>
                    <widget name="web_ribbon" title="Nouveau" bg_color="bg-info"
                            invisible="not is_new"/>
                    <group>
                        <group string="Identification">
                            <field name="ouvrage_id" readonly="1"/>
                            <field name="base_id" readonly="1"/>
                            <field name="sequence"/>
                            <field name="type_ligne" widget="badge"/>
                        </group>
                        <group string="Article">
                            <field name="quantite"/>
                            <field name="description"/>
                            <field name="reference"/>
                        </group>
                    </group>
                    <group>
                        <group string="Classification">
                            <field name="famille"/>
                            <field name="fabricant"/>
                            <field name="champ_utilisateur"/>
                        </group>
                        <group string="Base QDV source">
                            <field name="base_source"/>
                            <field name="chemin_base" readonly="1"/>
                            <field name="profondeur" readonly="1"/>
                            <field name="id_ouvrage_qdv" readonly="1"/>
                        </group>
                    </group>
                    <group string="Options QDV7">
                        <group>
                            <field name="toujours_importer"/>
                            <field name="gras"/>
                            <field name="italique"/>
                        </group>
                        <group>
                            <field name="souligne"/>
                            <field name="couleur"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================
         ACTION standalone (search définie avant)
    ============================================================ -->
    <record id="qdv_ouvrage_minute_action" model="ir.actions.act_window">
        <field name="name">Articles / Minutes</field>
        <field name="res_model">qdv.ouvrage.minute</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="qdv_ouvrage_minute_search"/>
    </record>

    <!-- ============================================================
         HÉRITAGE vue ouvrage : bouton stat + bouton header + onglet
    ============================================================ -->
    <record id="qdv_ouvrage_form_with_minutes" model="ir.ui.view">
        <field name="name">qdv.ouvrage.form.minutes</field>
        <field name="model">qdv.ouvrage</field>
        <field name="inherit_id" ref="qdv_ouvrage_form_view"/>
        <field name="arch" type="xml">

            <!-- Bouton stat après le ribbon -->
            <xpath expr="//widget[@name='web_ribbon']" position="after">
                <div class="oe_button_box" name="button_box">
                    <button name="action_view_minutes"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-list-ul"
                            invisible="minute_count == 0">
                        <field name="minute_count" widget="statinfo" string="Articles"/>
                    </button>
                </div>
            </xpath>

            <!-- Boutons dans le header -->
            <xpath expr="//header" position="inside">
                <button name="action_load_minutes"
                        string="📋 Charger les articles"
                        type="object"
                        class="btn-secondary"
                        help="Charge les articles/minutes depuis le fichier .grp"/>
                <button name="action_picker_articles"
                        string="🔍 Ajouter depuis catalogue"
                        type="object"
                        class="btn-primary"
                        help="Recherche et insère des articles depuis les catalogues tarifaires"/>
            </xpath>

            <!-- Champs cachés nécessaires au domaine/invisible -->
            <xpath expr="//sheet" position="inside">
                <field name="minute_count" invisible="1"/>
                <field name="minute_modified_count" invisible="1"/>
                <field name="has_blob" invisible="1"/>
            </xpath>

            <!-- Onglet Articles dans le notebook existant -->
            <xpath expr="//notebook/page[@name='notes']" position="before">
                <page string="📋 Articles / Minutes" name="minutes">
                    <field name="minute_ids"
                           context="{'default_ouvrage_id': id}">
                        <list string="Articles"
                              editable="bottom"
                              decoration-info="is_new"
                              decoration-warning="is_modified"
                              decoration-muted="type_ligne == 'main_oeuvre'">
                            <field name="sequence" widget="handle"/>
                            <field name="type_ligne" widget="badge"
                                   decoration-primary="type_ligne == 'materiel'"
                                   decoration-warning="type_ligne == 'main_oeuvre'"
                                   string="Type"/>
                            <field name="quantite" string="Qté"/>
                            <field name="description"/>
                            <field name="reference"/>
                            <field name="fabricant" optional="show"/>
                            <field name="famille" optional="hide"/>
                            <field name="base_source" string="Base QDV" optional="show"/>
                            <field name="champ_utilisateur" optional="hide"/>
                            <field name="is_modified" readonly="1" optional="show"/>
                            <field name="is_new" invisible="1"/>
                        </list>
                    </field>
                    <div class="alert alert-info mt-2" invisible="minute_count != 0">
                        <i class="fa fa-info-circle"/> Cliquez sur
                        <strong>"📋 Charger les articles"</strong>
                        (bouton en haut) pour lire les articles depuis le fichier .grp.
                    </div>
                </page>
            </xpath>

        </field>
    </record>

</odoo>
