<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="qdv_import_grp_wizard_form_view" model="ir.ui.view">
        <field name="name">qdv.import.grp.wizard.form</field>
        <field name="model">qdv.import.grp.wizard</field>
        <field name="arch" type="xml">
            <form string="Importer une base d'ouvrage QDV7">
                <sheet>
                    <!-- État draft : configuration -->
                    <group invisible="state != 'draft'">
                        <group string="Paramètres d'import">
                            <field name="base_id" readonly="state != 'draft'"/>
                            <field name="grp_file"
                                   widget="binary"
                                   filename="grp_filename"
                                   string="Fichier .grp (SQLite)"
                                   readonly="state != 'draft'"/>
                            <field name="grp_filename" invisible="1"/>
                            <field name="import_mode" readonly="state != 'draft'"/>
                        </group>
                        <group string="⚠️ Informations">
                            <div colspan="2">
                                <p>
                                    <strong>Remplacer :</strong> Efface tous les ouvrages existants
                                    de cette base et réimporte depuis le fichier .grp.<br/>
                                    <em>Recommandé pour le premier import.</em>
                                </p>
                                <p>
                                    <strong>Mettre à jour :</strong> Ajoute les nouveaux ouvrages et
                                    met à jour les existants non modifiés dans Odoo.<br/>
                                    <em>Préserve vos modifications Odoo.</em>
                                </p>
                            </div>
                        </group>
                    </group>

                    <!-- État done : résultats -->
                    <group invisible="state != 'done'" string="✅ Résultats de l'import">
                        <group>
                            <field name="familles_count" readonly="1"/>
                            <field name="ouvrages_count" readonly="1"/>
                            <field name="ouvrages_updated" readonly="1"/>
                        </group>
                    </group>
                    <field name="result_log"
                           invisible="state != 'done'"
                           readonly="1"
                           widget="text"
                           style="font-family: monospace; background: #f5f5f5; padding: 10px;"/>
                </sheet>
                <footer>
                    <button name="action_import"
                            string="📥 Importer"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button string="Fermer"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
