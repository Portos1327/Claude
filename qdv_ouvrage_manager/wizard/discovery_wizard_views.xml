<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         WIZARD DÉCOUVERTE - Formulaire principal
    ============================================================ -->
    <record id="qdv_discovery_wizard_form_view" model="ir.ui.view">
        <field name="name">qdv.discovery.wizard.form</field>
        <field name="model">qdv.discovery.wizard</field>
        <field name="arch" type="xml">
            <form string="🔍 Découverte des bases d'ouvrage QDV7">
                <sheet>

                    <!-- ===== ÉTAT SCAN (initial) ===== -->
                    <group invisible="state != 'scan'">
                        <group string="Configuration du scan">
                            <field name="config_id" readonly="state != 'scan'"/>
                        </group>
                        <group string="💡 Informations">
                            <div colspan="2">
                                <p>
                                    Le scan va parcourir le dossier configuré et détecter
                                    automatiquement tous les fichiers <strong>.grp</strong>
                                    (bases d'ouvrage QDV7).
                                </p>
                                <p>
                                    Dossier configuré :
                                    <code>C:\Users\dimitri\Mon Drive\Base QDV\Base article et ouvrage</code>
                                </p>
                                <p>
                                    Modifiez le dossier dans
                                    <strong>QDV Ouvrages → Configuration</strong> si nécessaire.
                                </p>
                            </div>
                        </group>
                    </group>

                    <!-- ===== ÉTAT RESULTS ===== -->
                    <div invisible="state not in ('results', 'done')">
                        <!-- Statistiques -->
                        <div class="o_horizontal_separator" invisible="state != 'results'">
                            Résultats du scan
                        </div>
                        <group invisible="state != 'results'">
                            <group>
                                <field name="total_found" readonly="1"/>
                                <field name="total_new" readonly="1"/>
                            </group>
                            <group>
                                <field name="total_update" readonly="1"/>
                                <field name="total_already" readonly="1"/>
                            </group>
                        </group>

                        <!-- Tableau des fichiers découverts -->
                        <field name="discovered_ids"
                               invisible="state == 'done'"
                               string="Fichiers découverts">
                            <list editable="bottom"
                                  decoration-success="status == 'imported'"
                                  decoration-warning="status == 'update'"
                                  decoration-info="status == 'new'"
                                  decoration-muted="status == 'invalid'">
                                <field name="selected" widget="boolean_toggle"/>
                                <field name="file_name" readonly="1"/>
                                <field name="relative_path" readonly="1" optional="hide"/>
                                <field name="file_version" readonly="1"/>
                                <field name="ouvrage_count" readonly="1"/>
                                <field name="famille_count" readonly="1"/>
                                <field name="file_size_kb" string="Taille (Ko)" readonly="1"/>
                                <field name="existing_base_name" readonly="1" optional="show"/>
                                <field name="status" readonly="1" widget="badge"
                                       decoration-success="status == 'imported'"
                                       decoration-warning="status == 'update'"
                                       decoration-info="status == 'new'"
                                       decoration-danger="status == 'invalid'"/>
                                <field name="action" readonly="1" optional="show"/>
                                <field name="existing_base_id" invisible="1"/>
                                <field name="file_path" invisible="1"/>
                            </list>
                        </field>

                        <!-- Boutons de sélection rapide -->
                        <div class="text-muted mt-2" invisible="state == 'done'">
                            <button name="action_select_all_new"
                                    string="Sélectionner tous les nouveaux"
                                    type="object"
                                    class="btn btn-link btn-sm"/>
                            <button name="action_select_all_update"
                                    string="+ À mettre à jour"
                                    type="object"
                                    class="btn btn-link btn-sm"/>
                            <button name="action_deselect_all"
                                    string="Tout désélectionner"
                                    type="object"
                                    class="btn btn-link btn-sm text-danger"/>
                        </div>
                    </div>

                    <!-- Journal (affiché dans tous les états sauf scan initial) -->
                    <div class="o_horizontal_separator"
                         invisible="state == 'scan'">
                        Journal
                    </div>
                    <field name="result_log"
                           invisible="state == 'scan'"
                           readonly="1"
                           widget="text"
                           style="font-family: monospace; font-size: 12px; background: #f8f9fa;
                                  padding: 10px; border-radius: 4px; min-height: 100px;"/>

                </sheet>

                <footer>
                    <!-- Bouton scan -->
                    <button name="action_scan"
                            string="🔍 Scanner le dossier"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'scan'"/>

                    <!-- Bouton rescanner -->
                    <button name="action_scan"
                            string="🔄 Rescanner"
                            type="object"
                            class="btn-secondary"
                            invisible="state not in ('results',)"/>

                    <!-- Bouton importer sélectionnés -->
                    <button name="action_import_selected"
                            string="📥 Importer la sélection"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'results'"/>

                    <button string="Fermer"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action découverte (menu direct) -->
    <record id="qdv_discovery_wizard_action" model="ir.actions.act_window">
        <field name="name">🔍 Découverte des bases d'ouvrage</field>
        <field name="res_model">qdv.discovery.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_config_id': 1}</field>
    </record>

</odoo>
