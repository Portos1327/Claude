<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vue Formulaire de Configuration -->
    <record id="view_vst_config_form" model="ir.ui.view">
        <field name="name">vst.config.form</field>
        <field name="model">vst.config</field>
        <field name="arch" type="xml">
            <form string="Configuration VST">
                <sheet>
                    <div class="oe_title">
                        <h1>Configuration VST Article Manager</h1>
                    </div>
                    
                    <div class="alert alert-info" role="alert">
                        <strong>📋 Information :</strong>
                        Ce module permet d'importer les articles depuis le fichier BATIGEST généré par l'exécutable VST.
                    </div>
                    
                    <group>
                        <group string="Chemins de l'exécutable">
                            <field name="executable_path"/>
                            <button name="action_test_executable" string="✓ Tester l'exécutable" 
                                    type="object" class="btn-secondary"/>
                            <field name="output_folder"/>
                            <button name="action_test_output_folder" string="✓ Tester le dossier" 
                                    type="object" class="btn-secondary"/>
                            <field name="output_filename"/>
                        </group>
                        
                        <group string="Fournisseur Odoo">
                            <field name="supplier_id"/>
                            <field name="supplier_delay"/>
                        </group>
                    </group>
                    
                    <group>
                        <group string="Options d'import par défaut">
                            <field name="update_existing"/>
                            <field name="auto_create_product"/>
                            <field name="create_price_history"/>
                        </group>
                        
                        <group string="Planification">
                            <field name="auto_update_enabled"/>
                        </group>
                    </group>
                    
                    <group string="Templates d'export Naviwest">
                        <field name="template_beg"/>
                        <field name="template_niedax"/>
                        <field name="template_cables"/>
                        <button name="action_test_templates" string="✓ Vérifier les templates" 
                                type="object" class="btn-secondary"/>
                    </group>
                    
                    <group string="Statistiques">
                        <group>
                            <field name="last_import_date"/>
                            <field name="last_import_count"/>
                        </group>
                        <group>
                            <field name="total_articles"/>
                            <field name="total_products"/>
                        </group>
                    </group>
                    
                    <group string="Actions rapides">
                        <div>
                            <button name="action_run_executable" string="🚀 Lancer l'exécutable BATIGEST" 
                                    type="object" class="btn-primary me-2"/>
                            <button name="action_open_import_wizard" string="📥 Importer les articles" 
                                    type="object" class="btn-secondary me-2"/>
                            <button name="action_full_update" string="🔄 Mise à jour complète" 
                                    type="object" class="btn-success"/>
                        </div>
                    </group>
                    
                    <group string="Dernier log" invisible="not last_log">
                        <field name="last_log" nolabel="1" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action pour ouvrir la Configuration -->
    <record id="action_vst_config" model="ir.actions.act_window">
        <field name="name">Configuration VST</field>
        <field name="res_model">vst.config</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>

    <!-- Action pour ouvrir automatiquement la config existante ou en créer une -->
    <record id="action_vst_config_singleton" model="ir.actions.server">
        <field name="name">Configuration VST</field>
        <field name="model_id" ref="model_vst_config"/>
        <field name="state">code</field>
        <field name="code">
config = env['vst.config'].get_config()
action = {
    'type': 'ir.actions.act_window',
    'res_model': 'vst.config',
    'res_id': config.id,
    'view_mode': 'form',
    'target': 'current',
}
        </field>
    </record>

</odoo>
