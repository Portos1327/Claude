<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vue Formulaire du Wizard d'Import -->
    <record id="view_import_articles_wizard_form" model="ir.ui.view">
        <field name="name">import.articles.wizard.form</field>
        <field name="model">import.articles.wizard</field>
        <field name="arch" type="xml">
            <form string="Importer les articles Rexel">
                <sheet>
                    <!-- Choix du mode d'import -->
                    <group>
                        <field name="import_mode" widget="radio"/>
                    </group>
                    
                    <!-- Import Excel -->
                    <group string="📁 Fichier Excel" invisible="import_mode != 'excel'">
                        <group>
                            <field name="excel_file" filename="excel_filename"/>
                            <field name="excel_filename" invisible="1"/>
                        </group>
                    </group>
                    
                    <!-- Import API -->
                    <group string="🌐 Configuration API" invisible="import_mode != 'api'">
                        <group>
                            <field name="use_api_config"/>
                            <field name="api_customer_id" invisible="use_api_config"/>
                            <field name="api_customer_scope" invisible="use_api_config"/>
                        </group>
                    </group>
                    
                    <!-- Options d'import avec onglets -->
                    <notebook>
                        <page string="📋 Mode d'import" name="import_mode_page">
                            <group>
                                <group string="Que souhaitez-vous faire ?">
                                    <field name="import_mode_articles" widget="radio"/>
                                </group>
                                <group string="Options">
                                    <field name="create_products"/>
                                    <field name="create_families"/>
                                </group>
                            </group>
                        </page>
                        
                        <page string="🔧 Champs à mettre à jour" name="fields_page"
                              invisible="import_mode_articles == 'new_only'">
                            <div class="alert alert-info" role="alert">
                                <p><strong>💡 Sélectionnez les informations à mettre à jour</strong> pour les articles existants.</p>
                            </div>
                            <group>
                                <group>
                                    <field name="update_prices"/>
                                    <field name="update_designation"/>
                                    <field name="update_famille"/>
                                    <field name="update_d3e"/>
                                </group>
                                <group>
                                    <field name="update_conditionnement"/>
                                    <field name="update_dates"/>
                                    <field name="update_other"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                    
                    <!-- Ancien champ masqué pour compatibilité -->
                    <field name="update_existing" invisible="1"/>
                    
                    <!-- Statistiques (visibles après import) -->
                    <group string="✅ Résultats de l'import" invisible="articles_imported == 0 and articles_updated == 0 and articles_skipped == 0">
                        <group>
                            <field name="articles_imported" readonly="1"/>
                            <field name="articles_updated" readonly="1"/>
                        </group>
                        <group>
                            <field name="articles_skipped" readonly="1"/>
                            <field name="families_created" readonly="1"/>
                        </group>
                    </group>
                    
                    <!-- Log d'import -->
                    <notebook invisible="not import_log">
                        <page string="📝 Log d'import">
                            <field name="import_log" nolabel="1" readonly="1"
                                   style="font-family: monospace; white-space: pre-wrap;"/>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button string="🚀 Importer" name="action_import" type="object" class="btn-primary"
                            invisible="articles_imported > 0 or articles_updated > 0"/>
                    <button string="Fermer" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action pour ouvrir le Wizard d'Import -->
    <record id="action_import_articles_wizard" model="ir.actions.act_window">
        <field name="name">📥 Importer des articles</field>
        <field name="res_model">import.articles.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_rexel_article"/>
    </record>

</odoo>
