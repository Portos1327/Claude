<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Wizard Import par Référence Form View -->
    <record id="view_import_reference_wizard_form" model="ir.ui.view">
        <field name="name">import.reference.wizard.form</field>
        <field name="model">import.reference.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Rapide par Référence">
                <group invisible="state != 'draft'">
                    <group string="Références à importer" colspan="2">
                        <field name="reference_input" nolabel="1" 
                               placeholder="Entrez une ou plusieurs références (une par ligne)&#10;&#10;Formats acceptés:&#10;  SCH APCRBCV202&#10;  LEG 406773&#10;  BE491028"
                               style="min-height: 200px; font-family: monospace;"/>
                    </group>
                    
                    <group string="Options">
                        <field name="create_families"/>
                        <field name="update_existing"/>
                        <field name="fetch_units"/>
                    </group>
                    
                    <div class="alert alert-info" role="alert">
                        <strong>ℹ️ Comment ça marche ?</strong>
                        <ul>
                            <li>Entrez des références au format <code>TRIGRAMME REFERENCE</code> (ex: <code>SCH APCRBCV202</code>)</li>
                            <li>Ou des références Rexel complètes (ex: <code>BE491028</code>)</li>
                            <li>L'API Rexel sera appelée pour récupérer les informations produit</li>
                            <li>Les articles seront créés ou mis à jour dans Odoo</li>
                        </ul>
                    </div>
                </group>
                
                <group invisible="state != 'done'">
                    <group string="Résultat">
                        <field name="articles_created"/>
                        <field name="articles_updated"/>
                        <field name="articles_errors"/>
                    </group>
                    
                    <group string="Journal d'import" colspan="2">
                        <field name="result_log" nolabel="1" readonly="1"
                               style="min-height: 200px; font-family: monospace; white-space: pre;"/>
                    </group>
                </group>
                
                <field name="state" invisible="1"/>
                
                <footer>
                    <button string="🚀 Importer" name="action_import" type="object" 
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button string="📋 Voir les articles" name="action_view_articles" type="object" 
                            class="btn-secondary" invisible="state != 'done'"/>
                    <button string="⬅ Nouvelle saisie" name="action_back" type="object" 
                            class="btn-secondary" invisible="state != 'done'"/>
                    <button string="Fermer" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action pour ouvrir le wizard -->
    <record id="action_import_reference_wizard" model="ir.actions.act_window">
        <field name="name">Import par Référence</field>
        <field name="res_model">import.reference.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
