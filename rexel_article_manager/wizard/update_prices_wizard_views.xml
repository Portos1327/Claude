<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vue Formulaire du Wizard de mise à jour des articles -->
    <record id="view_update_prices_wizard_form" model="ir.ui.view">
        <field name="name">update.prices.wizard.form</field>
        <field name="model">update.prices.wizard</field>
        <field name="arch" type="xml">
            <form string="Mettre à jour les articles via API Rexel">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        <strong>ℹ️ Information :</strong> Cette opération va se connecter à l'API Rexel Cloud pour récupérer les informations actuelles des articles (prix, désignation, unité, écotaxe, etc.).
                        Les articles non retrouvés seront marqués comme obsolètes.
                    </div>
                    
                    <group>
                        <group string="Mode de mise à jour">
                            <field name="update_mode" widget="radio"/>
                        </group>
                        <group string="Statistiques">
                            <field name="articles_count" readonly="1"/>
                        </group>
                    </group>
                    
                    <!-- Filtres (visibles uniquement en mode filtre) -->
                    <group string="Filtres" invisible="update_mode != 'filter'">
                        <group>
                            <field name="filter_famille" placeholder="Ex: Câbles"/>
                        </group>
                        <group>
                            <field name="filter_fabricant" placeholder="Ex: Schneider"/>
                        </group>
                    </group>
                    
                    <!-- Options -->
                    <group string="Options">
                        <group>
                            <field name="create_history"/>
                            <field name="update_products"/>
                        </group>
                        <group>
                            <field name="mark_obsolete"/>
                            <field name="fetch_units"/>
                        </group>
                    </group>
                    
                    <!-- Résultats (visibles après exécution) -->
                    <group string="Résultats" invisible="articles_updated == 0 and errors_count == 0 and articles_obsolete == 0">
                        <group>
                            <field name="articles_updated" readonly="1"/>
                            <field name="prices_changed" readonly="1"/>
                            <field name="units_updated" readonly="1"/>
                        </group>
                        <group>
                            <field name="articles_obsolete" readonly="1" class="text-warning"/>
                            <field name="errors_count" readonly="1" class="text-danger"/>
                        </group>
                    </group>
                    
                    <!-- Log de mise à jour -->
                    <notebook invisible="not update_log">
                        <page string="Log de mise à jour">
                            <field name="update_log" nolabel="1" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button string="Mettre à jour" name="action_update_prices" type="object" class="btn-primary" invisible="articles_updated > 0 or articles_obsolete > 0"/>
                    <button string="Fermer" name="action_close" type="object" class="btn-secondary" invisible="articles_updated == 0 and articles_obsolete == 0"/>
                    <button string="Annuler" class="btn-secondary" special="cancel" invisible="articles_updated > 0 or articles_obsolete > 0"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action pour le wizard -->
    <record id="action_update_prices_wizard" model="ir.actions.act_window">
        <field name="name">Mettre à jour les articles (API)</field>
        <field name="res_model">update.prices.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_rexel_article"/>
    </record>

</odoo>
