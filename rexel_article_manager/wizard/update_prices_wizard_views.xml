<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vue Formulaire du Wizard de mise à jour des articles -->
    <record id="view_update_prices_wizard_form" model="ir.ui.view">
        <field name="name">update.prices.wizard.form</field>
        <field name="model">update.prices.wizard</field>
        <field name="arch" type="xml">
            <form string="🔄 Mettre à jour les articles via API Rexel">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        <p><strong>ℹ️ Mise à jour via API Rexel Cloud</strong></p>
                        <p>Sélectionnez les APIs à appeler pour récupérer les informations actuelles des articles.</p>
                    </div>
                    
                    <group>
                        <group string="Mode de mise à jour">
                            <field name="update_mode" widget="radio"/>
                        </group>
                        <group string="Statistiques">
                            <field name="articles_count" readonly="1"/>
                        </group>
                    </group>
                    
                    <!-- Filtres avancés (visibles uniquement en mode filtre) -->
                    <notebook invisible="update_mode != 'filter'">
                        <page string="🔍 Filtres par liste" name="filters_list">
                            <group>
                                <group string="Hiérarchie produit">
                                    <field name="filter_famille_id" 
                                           options="{'no_create': True, 'no_open': True}"
                                           placeholder="Sélectionner une famille..."/>
                                    <field name="filter_sous_famille_id" 
                                           options="{'no_create': True, 'no_open': True}"
                                           placeholder="Sélectionner une sous-famille..."
                                           invisible="not filter_famille_id"/>
                                    <field name="filter_fonction_id" 
                                           options="{'no_create': True, 'no_open': True}"
                                           placeholder="Sélectionner une fonction..."
                                           invisible="not filter_sous_famille_id"/>
                                </group>
                                <group string="Fabricant">
                                    <field name="filter_fabricant"/>
                                </group>
                            </group>
                            <group>
                                <group string="Statut article">
                                    <field name="filter_obsolete"/>
                                    <field name="filter_with_product"/>
                                    <field name="filter_selection_durable"/>
                                    <field name="filter_import_source"/>
                                </group>
                            </group>
                        </page>
                        <page string="✏️ Filtres manuels (texte)" name="filters_text">
                            <group>
                                <group string="Recherche par texte">
                                    <field name="filter_famille_text" placeholder="Ex: Câbles..."/>
                                    <field name="filter_fabricant_text" placeholder="Ex: Schneider..."/>
                                </group>
                                <group string="Recherche article">
                                    <field name="filter_reference" placeholder="Ex: A9F74106"/>
                                    <field name="filter_designation" placeholder="Ex: Disjoncteur"/>
                                </group>
                            </group>
                            <div class="alert alert-secondary" role="alert">
                                <p><strong>💡 Astuce</strong> : Les filtres texte permettent une recherche partielle. 
                                Vous pouvez combiner les filtres de l'onglet "Liste" avec ceux de cet onglet.</p>
                            </div>
                        </page>
                    </notebook>
                    
                    <!-- APIs Pack Découverte -->
                    <group string="📦 APIs Pack Découverte">
                        <group>
                            <field name="fetch_prices"/>
                            <field name="fetch_units"/>
                        </group>
                        <group>
                            <field name="fetch_stocks"/>
                        </group>
                    </group>
                    
                    <!-- APIs Pack Premium -->
                    <group string="⭐ APIs Pack Premium">
                        <group>
                            <field name="fetch_images"/>
                            <field name="fetch_fiches"/>
                            <field name="fetch_cee"/>
                        </group>
                        <group>
                            <field name="fetch_env"/>
                            <field name="fetch_replacement"/>
                        </group>
                    </group>
                    
                    <!-- Options Performance -->
                    <group string="⚡ Performance (Unités)" invisible="not fetch_units">
                        <group>
                            <field name="use_parallel"/>
                        </group>
                        <group>
                            <field name="parallel_workers" invisible="not use_parallel"/>
                        </group>
                        <div class="alert alert-warning" role="alert" invisible="not use_parallel" colspan="2">
                            <p><strong>⚠️ Mode parallèle</strong> - Recommandé pour &gt;100 articles. 
                            Gain de temps: ~5-10x plus rapide. 
                            Attention: augmente la charge sur les serveurs Rexel.</p>
                        </div>
                    </group>
                    
                    <!-- Options générales -->
                    <group string="⚙️ Options générales">
                        <group>
                            <field name="create_history"/>
                            <field name="update_products"/>
                        </group>
                        <group>
                            <field name="mark_obsolete"/>
                        </group>
                    </group>
                    
                    <!-- Résultats (visibles après exécution) -->
                    <group string="✅ Résultats" invisible="articles_updated == 0 and errors_count == 0 and articles_obsolete == 0">
                        <group>
                            <field name="articles_updated" readonly="1"/>
                            <field name="prices_changed" readonly="1"/>
                            <field name="units_updated" readonly="1"/>
                        </group>
                        <group>
                            <field name="articles_obsolete" readonly="1"/>
                            <field name="errors_count" readonly="1"/>
                        </group>
                    </group>
                    
                    <!-- Log de mise à jour -->
                    <notebook invisible="not update_log">
                        <page string="📋 Log de mise à jour">
                            <field name="update_log" nolabel="1" readonly="1" 
                                   style="font-family: monospace; white-space: pre;"/>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button string="🚀 Lancer la mise à jour" name="action_update_prices" type="object" 
                            class="btn-primary" invisible="articles_updated > 0 or articles_obsolete > 0"/>
                    <button string="Fermer" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action pour le wizard -->
    <record id="action_update_prices_wizard" model="ir.actions.act_window">
        <field name="name">🔄 Mettre à jour les articles (API)</field>
        <field name="res_model">update.prices.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_rexel_article"/>
    </record>

</odoo>
