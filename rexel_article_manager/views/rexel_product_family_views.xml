<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vue Liste arborescente des Familles -->
    <record id="view_rexel_product_family_tree" model="ir.ui.view">
        <field name="name">rexel.product.family.tree</field>
        <field name="model">rexel.product.family</field>
        <field name="arch" type="xml">
            <list string="Familles de Produits" expand="1" editable="top">
                <field name="code" optional="show"/>
                <field name="name"/>
                <field name="parent_id" invisible="1"/>
                <field name="level"/>
                <field name="article_count" string="Nb articles"/>
                <button name="action_view_articles" 
                        string="Voir" 
                        type="object" 
                        icon="fa-eye" 
                        invisible="article_count == 0"/>
            </list>
        </field>
    </record>

    <!-- Vue Formulaire des Familles -->
    <record id="view_rexel_product_family_form" model="ir.ui.view">
        <field name="name">rexel.product.family.form</field>
        <field name="model">rexel.product.family</field>
        <field name="arch" type="xml">
            <form string="Famille de Produits">
                <header>
                    <button name="action_view_articles" 
                            string="Voir les articles" 
                            type="object" 
                            class="btn-primary" 
                            invisible="article_count == 0"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_articles" 
                                type="object" 
                                class="oe_stat_button" 
                                icon="fa-cubes">
                            <field name="article_count" widget="statinfo" string="Articles"/>
                        </button>
                    </div>
                    
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="parent_id"/>
                            <field name="level"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Enfants" invisible="not child_ids">
                            <field name="child_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="level"/>
                                    <field name="article_count"/>
                                    <button name="action_view_articles" 
                                            string="Voir" 
                                            type="object" 
                                            icon="fa-eye"/>
                                </list>
                            </field>
                        </page>
                        
                        <page string="Articles" invisible="not article_ids">
                            <field name="article_ids">
                                <list>
                                    <field name="reference_fabricant"/>
                                    <field name="designation"/>
                                    <field name="prix_net"/>
                                    <field name="unite_mesure"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vue Recherche -->
    <record id="view_rexel_product_family_search" model="ir.ui.view">
        <field name="name">rexel.product.family.search</field>
        <field name="model">rexel.product.family</field>
        <field name="arch" type="xml">
            <search string="Rechercher Familles">
                <field name="name"/>
                <field name="code"/>
                <field name="parent_id"/>
                
                <filter string="Racines (Familles)" name="level_famille" domain="[('level', '=', 'famille')]"/>
                <filter string="Sous-familles" name="level_sous_famille" domain="[('level', '=', 'sous_famille')]"/>
                <filter string="Fonctions" name="level_fonction" domain="[('level', '=', 'fonction')]"/>
                <filter string="Lidic" name="level_lidic" domain="[('level', '=', 'lidic')]"/>
                <filter string="Gammes" name="level_gamme" domain="[('level', '=', 'gamme')]"/>
                
                <separator/>
                <filter string="Nœuds racines" name="root_nodes" domain="[('parent_id', '=', False)]"/>
                
                <separator/>
                <filter string="Archivé" name="inactive" domain="[('active', '=', False)]"/>
                
                <group expand="0" string="Regrouper par">
                    <filter string="Famille" name="group_famille" context="{'group_by': 'parent_id'}"/>
                    <filter string="Sous-famille" name="group_sous_famille" context="{'group_by': 'parent_id'}"/>
                    <filter string="Fonction" name="group_fonction" context="{'group_by': 'parent_id'}"/>
                    <filter string="Niveau" name="group_level" context="{'group_by': 'level'}"/>
                    <filter string="Parent" name="group_parent" context="{'group_by': 'parent_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action principale -->
    <record id="action_rexel_product_family" model="ir.actions.act_window">
        <field name="name">Familles de Produits</field>
        <field name="res_model">rexel.product.family</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_root_nodes': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune famille de produits
            </p>
            <p>
                Cliquez sur "Action" → "Reconstruire la hiérarchie" pour créer l'arborescence depuis vos articles.
            </p>
        </field>
    </record>

    <!-- Action serveur pour reconstruire la hiérarchie -->
    <record id="action_rebuild_family_hierarchy" model="ir.actions.server">
        <field name="name">🔄 Reconstruire la hiérarchie</field>
        <field name="model_id" ref="model_rexel_product_family"/>
        <field name="binding_model_id" ref="model_rexel_product_family"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">
# Reconstruire la hiérarchie depuis tous les articles
result = env['rexel.product.family'].rebuild_hierarchy_from_articles()

# Afficher un message de succès
if result:
    # Compter les familles créées
    family_count = env['rexel.product.family'].search_count([])
    action = {
        'type': 'ir.actions.client',
        'tag': 'display_notification',
        'params': {
            'title': 'Hiérarchie reconstruite !',
            'message': f'{family_count} nœuds créés dans l\'arborescence',
            'type': 'success',
            'sticky': False,
            'next': {'type': 'ir.actions.act_window_close'},
        }
    }
        </field>
    </record>

</odoo>
