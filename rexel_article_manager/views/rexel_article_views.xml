        <field name="model_id" ref="model_rexel_article"/>
        <field name="binding_model_id" ref="model_rexel_article"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
if records:
    action = records.action_fetch_stocks_batch()
        </field>
    </record>
    
    <!-- Action serveur: Récupérer les prix API -->
    <record id="action_fetch_prices_batch" model="ir.actions.server">
        <field name="name">💰 Récupérer les prix (API)</field>
        <field name="model_id" ref="model_rexel_article"/>
        <field name="binding_model_id" ref="model_rexel_article"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
if records:
    action = records.action_fetch_prices_batch()
        </field>
    </record>
    
    <!-- Action serveur: Récupérer TOUTES les données API -->
    <record id="action_fetch_all_api_data" model="ir.actions.server">
        <field name="name">🔄 Récupérer TOUTES les données API</field>
        <field name="model_id" ref="model_rexel_article"/>
        <field name="binding_model_id" ref="model_rexel_article"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
if records:
    action = records.action_fetch_all_api_data()
        </field>
    </record>
    
    <!-- Action serveur: Récupérer données Premium (images, CEE, etc.) -->
    <record id="action_fetch_premium_data" model="ir.actions.server">
        <field name="name">⭐ Récupérer données Premium (CEE, Eco, Remplacement)</field>
        <field name="model_id" ref="model_rexel_article"/>
        <field name="binding_model_id" ref="model_rexel_article"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
if records:
    action = records.action_fetch_premium_data()
        </field>
    </record>

    <!-- Action serveur: Recalculer les remises -->
    <record id="action_recalculate_discount" model="ir.actions.server">
        <field name="name">🔢 Recalculer les remises</field>
        <field name="model_id" ref="model_rexel_article"/>
        <field name="binding_model_id" ref="model_rexel_article"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
if records:
    action = records.action_recalculate_discount()
        </field>
    </record>
    
    <!-- Action serveur: Export Rexel Excel -->
    <record id="action_export_rexel" model="ir.actions.server">
        <field name="name">📤 Export vers Rexel Excel</field>
