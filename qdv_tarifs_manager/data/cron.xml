<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        CRON journalier - Surveillance et synchro des bases QDV
        Odoo 18: ir.cron sans numbercall/doall (dépréciés)
        Exécution quotidienne à 6h00 du matin
    -->
    <record id="ir_cron_qdv_tarif_daily_check" model="ir.cron">
        <field name="name">QDV Tarifs - Vérification quotidienne des fichiers</field>
        <field name="model_id" ref="model_qdv_tarif_cron_mixin"/>
        <field name="state">code</field>
        <field name="code">model.run_daily_check()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
        <field name="user_id" ref="base.user_root"/>
    </record>
</odoo>
