<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ======================================================== -->
    <!-- JOURNAL DE SYNCHRONISATION                                -->
    <!-- ======================================================== -->

    <record id="view_qdv_tarif_sync_log_list" model="ir.ui.view">
        <field name="name">qdv.tarif.sync.log.list</field>
        <field name="model">qdv.tarif.sync.log</field>
        <field name="arch" type="xml">
            <list string="Journal synchro QDV"
                  decoration-success="status == 'ok'"
                  decoration-warning="status == 'partial'"
                  decoration-danger="status == 'error'"
                  decoration-muted="status == 'nothing'"
                  default_order="sync_date desc">
                <field name="sync_date" string="Date/heure"/>
                <field name="trigger" string="Déclencheur" widget="badge"/>
                <field name="files_checked" string="Vérifiés"/>
                <field name="files_changed" string="Changés"
                       decoration-success="files_changed > 0"
                       decoration-muted="files_changed == 0"/>
                <field name="bases_synced" string="Bases sync."/>
                <field name="articles_created" string="Créés" optional="show"/>
                <field name="articles_updated" string="MAJ" optional="show"/>
                <field name="rebates_updated" string="Remises MAJ" optional="show"/>
                <field name="duration" string="Durée (s)" optional="show"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'ok'"
                       decoration-warning="status == 'partial'"
                       decoration-danger="status == 'error'"
                       decoration-muted="status == 'nothing'"/>
            </list>
        </field>
    </record>

    <record id="view_qdv_tarif_sync_log_form" model="ir.ui.view">
        <field name="name">qdv.tarif.sync.log.form</field>
        <field name="model">qdv.tarif.sync.log</field>
        <field name="arch" type="xml">
            <form string="Journal synchronisation QDV" duplicate="false">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="sync_date" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Résumé">
                            <field name="trigger" readonly="1"/>
                            <field name="status" widget="badge" readonly="1"/>
                            <field name="duration" readonly="1" string="Durée (s)"/>
                        </group>
                        <group string="Compteurs">
                            <field name="files_checked" readonly="1"/>
                            <field name="files_changed" readonly="1"/>
                            <field name="bases_synced" readonly="1"/>
                            <field name="articles_created" readonly="1"/>
                            <field name="articles_updated" readonly="1"/>
                            <field name="rebates_updated" readonly="1"/>
                        </group>
                    </group>
                    <group string="Journal détaillé">
                        <field name="detail" widget="text" readonly="1" nolabel="1"
                               style="font-family: monospace; font-size: 11px; min-height: 300px; white-space: pre;"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_qdv_tarif_sync_log" model="ir.actions.act_window">
        <field name="name">Journal synchronisation</field>
        <field name="res_model">qdv.tarif.sync.log</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Aucune synchronisation enregistrée</p>
            <p>Le CRON s'exécute chaque jour à 6h00 et log ici son activité.</p>
        </field>
    </record>

    <!-- ======================================================== -->
    <!-- SNAPSHOTS FICHIERS                                        -->
    <!-- ======================================================== -->

    <record id="view_qdv_tarif_file_snapshot_list" model="ir.ui.view">
        <field name="name">qdv.tarif.file.snapshot.list</field>
        <field name="model">qdv.tarif.file.snapshot</field>
        <field name="arch" type="xml">
            <list string="Snapshots fichiers surveillés"
                  decoration-danger="last_sync_result == 'error'"
                  decoration-success="last_sync_result == 'ok'"
                  decoration-muted="last_sync_result == 'no_change'">
                <field name="file_name" string="Fichier"/>
                <field name="file_type" string="Type" widget="badge"/>
                <field name="base_id" string="Base associée" optional="show"/>
                <field name="known_size" string="Taille connue (o)"/>
                <field name="last_sync_date" string="Dernière synchro"/>
                <field name="last_sync_result" string="Résultat" widget="badge"
                       decoration-success="last_sync_result == 'ok'"
                       decoration-danger="last_sync_result == 'error'"/>
                <field name="sync_count" string="Nb synchros"/>
                <field name="last_sync_message" string="Message" optional="show"/>
            </list>
        </field>
    </record>

    <record id="action_qdv_tarif_file_snapshot" model="ir.actions.act_window">
        <field name="name">Fichiers surveillés</field>
        <field name="res_model">qdv.tarif.file.snapshot</field>
        <field name="view_mode">list</field>
    </record>

    <!-- ======================================================== -->
    <!-- ACTION SERVEUR: LANCEMENT MANUEL DU CRON                 -->
    <!-- ======================================================== -->

    <record id="action_run_cron_now" model="ir.actions.server">
        <field name="name">▶ Lancer la vérification maintenant</field>
        <field name="model_id" ref="model_qdv_tarif_cron_mixin"/>
        <field name="state">code</field>
        <field name="code">model.run_daily_check()</field>
    </record>
</odoo>
