<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Vue formulaire du wizard de recherche SIMPLIFIÉ -->
    <record id="view_search_prices_wizard_form" model="ir.ui.view">
        <field name="name">search.prices.wizard.form</field>
        <field name="model">search.prices.wizard</field>
        <field name="arch" type="xml">
            <form string="Recherche de Fournisseurs">
                
                <!-- ÉTAPE 1: Recherche -->
                <group invisible="state != 'search'">
                    <group string="Mode">
                        <field name="mode" widget="radio"/>
                    </group>
                    
                    <group string="Produit existant" invisible="mode != 'existing'">
                        <field name="product_id" required="mode == 'existing'"/>
                    </group>
                    
                    <group string="Nouveau produit" invisible="mode != 'new'">
                        <field name="new_product_name" placeholder="Nom du produit (optionnel)"/>
                    </group>
                </group>
                
                <group invisible="state != 'search'">
                    <group string="Critères de recherche">
                        <field name="reference" placeholder="Ex: 0 721 21"/>
                        <field name="brand" placeholder="Ex: Legrand"/>
                    </group>
                </group>
                
                <!-- ÉTAPE 2: Résultats -->
                <group invisible="state != 'results'">
                    <group>
                        <field name="result_count" readonly="1"/>
                    </group>
                </group>
                
                <field name="result_ids" invisible="state != 'results'">
                    <list editable="bottom" create="0" delete="0"
                          decoration-muted="already_linked">
                        <field name="selected"/>
                        <field name="source_name" readonly="1" string="Source"/>
                        <field name="brand" readonly="1"/>
                        <field name="reference" readonly="1"/>
                        <field name="designation" readonly="1"/>
                        <field name="price" readonly="1"/>
                        <field name="already_linked" readonly="1" string="Déjà lié"/>
                        <button name="action_view_article" type="object"
                                string="Voir" icon="fa-external-link"/>
                    </list>
                </field>
                
                <!-- ÉTAPE 3: Terminé -->
                <group invisible="state != 'done'">
                    <div class="alert alert-success" role="alert">
                        <h4 class="alert-heading">✓ Fournisseurs ajoutés !</h4>
                        <p>Les fournisseurs sélectionnés ont été ajoutés à l'onglet Achats du produit.</p>
                    </div>
                </group>
                
                <field name="state" invisible="1"/>
                
                <footer>
                    <!-- Boutons étape 1: Recherche -->
                    <button name="action_search" type="object"
                            string="🔍 Rechercher"
                            class="btn-primary"
                            invisible="state != 'search'"/>
                    
                    <!-- Boutons étape 2: Résultats -->
                    <button name="action_select_all" type="object"
                            string="Tout"
                            class="btn-secondary"
                            invisible="state != 'results'"/>
                    <button name="action_select_none" type="object"
                            string="Rien"
                            class="btn-secondary"
                            invisible="state != 'results'"/>
                    <button name="action_select_best_price" type="object"
                            string="Meilleur prix"
                            class="btn-info"
                            invisible="state != 'results'"/>
                    <button name="action_apply_selection" type="object"
                            string="✓ Ajouter aux Achats"
                            class="btn-success"
                            invisible="state != 'results'"/>
                    
                    <button string="Fermer" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action pour ouvrir le wizard depuis le menu -->
    <record id="action_search_prices_wizard" model="ir.actions.act_window">
        <field name="name">Rechercher des Fournisseurs</field>
        <field name="res_model">search.prices.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_mode': 'new'}</field>
    </record>

</odoo>
